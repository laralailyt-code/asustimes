# ==============================================
# ASUSTIMES Telegram Bot — 環境變數範本
# 複製此檔為 .env 並填入實際值
# ==============================================

# Telegram Bot（@BotFather 取得）
TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# Webhook 安全 token（用 openssl rand -hex 32 產生）
TELEGRAM_WEBHOOK_SECRET=your-random-32-char-secret

# Webhook 路徑與公開 URL（部署後改這個）
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_PUBLIC_URL=https://asustimes.onrender.com

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_DB_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# 推播限速（Telegram 全域上限 30/s，留 buffer）
TELEGRAM_RATE_LIMIT_PER_SEC=25

# 管理員 chat_id（多個用逗號隔開，可選）
TELEGRAM_ADMIN_CHAT_IDS=

# 本地是否強制跑 polling（預設 false 避免跟 Render 衝突）
TELEGRAM_FORCE_LOCAL_POLLING=false
